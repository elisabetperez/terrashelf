# Copy to .env for local dev
SESSION_SECRET=replace-with-32-random-bytes-in-base64
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Domain-only ("terrahq.com") allows any @terrahq.com Google account.
# A full address ("you@example.com") allows exactly that address.
ALLOWED_EMAIL=terrahq.com
# Comma-separated admin allow-list. The first entry is the primary "Admin";
# the rest are shown as "Co-admin" but have identical permissions.
ADMIN_EMAILS=eli@terrahq.com,dalila.cabrera@terrahq.com
# Dev-only login (ignored in production builds). Lets you sign in locally
# without Google OAuth configured.
DEV_LOGIN_ENABLED=true
