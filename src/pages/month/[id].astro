---
import Layout from "@/components/Layout.astro";
import { getSession, isAdmin } from "@/lib/session";
import { getMonth, winnerBook, isValidPeriodId, displayLabel, scheduleText, monthName } from "@/lib/months";
import { getMembers } from "@/lib/membership";
import { listProfiles, readerCards, nameFromEmail } from "@/lib/profiles";

const session = getSession(Astro.cookies);
const admin = isAdmin(session?.email);
const id = Astro.params.id ?? "";

const month = session && isValidPeriodId(id) ? await getMonth(id) : null;
const winner = month ? winnerBook(month) : null;
const isClosed = month?.phase === "closed" && winner;
const members = isClosed ? await getMembers(id) : [];
const readers = members.length ? await readerCards(members) : [];
const joined = session ? members.includes(session.email) : false;

const monthLabel = month ? displayLabel(month) : isValidPeriodId(id) ? monthName(id) : id;
const monthDates = month ? scheduleText(month) : null;

// People that can be @mentioned: club members with a profile.
const profiles = isClosed ? await listProfiles() : [];
const mentionables = profiles.map((p) => ({
  handle: (p.email.split("@")[0] || "").toLowerCase().replace(/[^a-z0-9._-]/g, ""),
  name: p.displayName || nameFromEmail(p.email),
}));

function initials(name: string): string {
  return name.split(/\s+/).filter(Boolean).slice(0, 2).map((p) => p[0]?.toUpperCase() ?? "").join("");
}
---

<Layout title={`TerraShelf — ${monthLabel} discussion`} session={session} isAdmin={admin} active="home">
  <p><a href="/" class="muted">← This month</a></p>

  {!isClosed ? (
    <div class="empty card">
      <h2>No book of the month yet</h2>
      <p>There's no chosen book for {monthLabel}. Come back once voting has closed.</p>
    </div>
  ) : (
    <>
      <p><span class="month-pill">{monthLabel}</span>{monthDates && <span class="muted" style="margin-left:0.6rem">{monthDates}</span>}</p>
      <div class="hero card">
        {winner!.coverUrl ? <img class="hero__cover" src={winner!.coverUrl} alt="" /> : <div class="hero__cover"></div>}
        <div class="hero__body">
          <div class="hero__kicker">Book of the month</div>
          <h1 class="hero__title">{winner!.title}</h1>
          <div class="hero__author">{winner!.author}</div>
          <div class="hero__actions">
            <button class="btn js-join" id="join-btn" data-joined={joined ? "1" : "0"}>
              {joined ? "Leave this read" : "Join this read"}
            </button>
          </div>
          <div class="readers" id="readers" style="margin-top:0.9rem">
            {readers.map((r) => (
              <span class="reader">
                {r.avatarUrl ? <img class="avatar avatar--sm" src={r.avatarUrl} alt="" /> : <span class="avatar avatar--sm avatar--ph">{initials(r.displayName)}</span>}
                <span class="reader__name">{r.displayName}</span>
              </span>
            ))}
          </div>
          <p class="muted" id="readers-empty" style={readers.length ? "display:none" : ""}>No readers yet — be the first to join.</p>
        </div>
      </div>

      <div class="card" id="chat" data-month={id} data-mentionables={JSON.stringify(mentionables)} style="margin-top:1.25rem;padding:1.25rem">
        <div class="row" style="justify-content:space-between;align-items:center">
          <p class="section-label" style="margin:0">Discussion · newest first</p>
          <label style="display:flex;align-items:center;gap:0.4rem;margin:0;font-weight:600;font-size:0.85rem">
            Chapter
            <select id="topic-filter"><option value="">All</option></select>
          </label>
        </div>
        <form class="chat__form" id="new-thread" style="flex-wrap:wrap">
          <input type="text" id="new-topic" list="topic-list" placeholder="Chapter / topic (optional)" autocomplete="off" style="flex:0 0 200px" />
          <input type="text" name="text" maxlength="280" placeholder="Start a new thread… (use @ to mention)" autocomplete="off" style="flex:1;min-width:180px" />
          <button class="btn" type="submit">Post</button>
        </form>
        <datalist id="topic-list"></datalist>
        <div class="threads" id="threads"></div>
      </div>
    </>
  )}
</Layout>

<script>
  type Reactions = Record<string, string[]>;
  type Msg = { id: string; author: string; text: string; createdAt: string; parentId: string | null; reactions: Reactions; topic: string | null };
  type Reader = { email: string; displayName: string; avatarUrl: string };
  type Mentionable = { handle: string; name: string };

  const chat = document.getElementById("chat");
  if (chat) {
    const month = (chat as HTMLElement).dataset.month!;
    const mentionables: Mentionable[] = JSON.parse((chat as HTMLElement).dataset.mentionables || "[]");
    const handleSet = new Set(mentionables.map((m) => m.handle));
    const threadsEl = document.getElementById("threads")!;
    const newThreadForm = document.getElementById("new-thread") as HTMLFormElement;
    let me = "";
    let isAdmin = false;
    let allowed: string[] = [];
    let lastSig = "";
    let currentMessages: Msg[] = [];
    let topicFilter = "";
    const topicFilterEl = document.getElementById("topic-filter") as HTMLSelectElement;
    const topicListEl = document.getElementById("topic-list") as HTMLDataListElement;

    const nameOnly = (e: string) => (e.includes("@") ? e.slice(0, e.indexOf("@")) : e);
    const fmt = (iso: string) => {
      const d = new Date(iso);
      return Number.isNaN(d.getTime()) ? "" : d.toLocaleString("en-US", { hour: "2-digit", minute: "2-digit", day: "2-digit", month: "short" });
    };

    // Render message text with @mentions highlighted (no innerHTML — safe).
    function renderText(el: HTMLElement, text: string) {
      const re = /@([a-zA-Z0-9._-]+)/g;
      let last = 0;
      let m: RegExpExecArray | null;
      while ((m = re.exec(text))) {
        if (m.index > last) el.appendChild(document.createTextNode(text.slice(last, m.index)));
        const span = document.createElement("span");
        span.className = "mention" + (handleSet.has(m[1].toLowerCase()) ? " is-known" : "");
        span.textContent = "@" + m[1];
        el.appendChild(span);
        last = re.lastIndex;
      }
      if (last < text.length) el.appendChild(document.createTextNode(text.slice(last)));
    }

    function reactionsBar(m: Msg): HTMLElement {
      const bar = document.createElement("div");
      bar.className = "reactions";
      for (const [emoji, users] of Object.entries(m.reactions)) {
        if (!users.length) continue;
        const chip = document.createElement("button");
        chip.className = "rx" + (users.includes(me) ? " is-mine" : "");
        chip.title = users.map(nameOnly).join(", ");
        chip.textContent = `${emoji} ${users.length}`;
        chip.addEventListener("click", () => react(m.id, emoji));
        bar.append(chip);
      }
      const add = document.createElement("span");
      add.className = "rx-add-wrap";
      const addBtn = document.createElement("button");
      addBtn.className = "rx rx-add";
      addBtn.textContent = "+";
      const picker = document.createElement("span");
      picker.className = "rx-picker";
      for (const emoji of allowed) {
        const b = document.createElement("button");
        b.textContent = emoji;
        b.addEventListener("click", () => { picker.classList.remove("is-open"); react(m.id, emoji); });
        picker.append(b);
      }
      addBtn.addEventListener("click", () => picker.classList.toggle("is-open"));
      add.append(addBtn, picker);
      bar.append(add);
      return bar;
    }

    function messageEl(m: Msg, isRoot: boolean): HTMLElement {
      const item = document.createElement("div");
      item.className = isRoot ? "msg msg--root" : "msg msg--reply";
      const head = document.createElement("div");
      head.className = "msg__head";
      const author = document.createElement("span");
      author.className = "msg__author";
      author.textContent = nameOnly(m.author);
      const time = document.createElement("span");
      time.className = "msg__time";
      time.textContent = fmt(m.createdAt);
      head.append(author, time);
      if (isRoot && m.topic) {
        const chip = document.createElement("span");
        chip.className = "topic-chip";
        chip.textContent = m.topic;
        head.append(chip);
      }
      if (m.author === me) {
        const del = document.createElement("button");
        del.className = "msg__del";
        del.textContent = "delete";
        del.addEventListener("click", () => remove(m.id));
        head.append(del);
      }
      const text = document.createElement("p");
      text.className = "msg__text";
      renderText(text, m.text);
      item.append(head, text, reactionsBar(m));
      return item;
    }

    function updateTopicControls(messages: Msg[]) {
      const topics = [...new Set(messages.filter((m) => m.parentId === null && m.topic).map((m) => m.topic as string))].sort();
      topicListEl.innerHTML = "";
      topicFilterEl.innerHTML = `<option value="">All</option>`;
      for (const t of topics) {
        const opt = document.createElement("option");
        opt.value = t;
        topicListEl.append(opt);
        const fopt = document.createElement("option");
        fopt.value = t;
        fopt.textContent = t;
        topicFilterEl.append(fopt);
      }
      topicFilterEl.value = topics.includes(topicFilter) ? topicFilter : "";
      topicFilter = topicFilterEl.value;
    }

    function render(messages: Msg[]) {
      currentMessages = messages;
      const sig = JSON.stringify(messages.map((m) => [m.id, m.topic, Object.entries(m.reactions).map(([k, v]) => k + v.length).join()])) + me + "|" + topicFilter;
      if (sig === lastSig) return;
      if (chat!.contains(document.activeElement) && (document.activeElement as HTMLElement)?.closest("form") && lastSig !== "") return;
      lastSig = sig;
      updateTopicControls(messages);
      threadsEl.innerHTML = "";
      const repliesByParent = new Map<string, Msg[]>();
      for (const m of messages) {
        if (m.parentId) {
          const arr = repliesByParent.get(m.parentId) ?? [];
          arr.push(m);
          repliesByParent.set(m.parentId, arr);
        }
      }
      // Newest threads first, by latest activity (root or any reply).
      const roots = messages.filter((m) => m.parentId === null && (!topicFilter || m.topic === topicFilter));
      const lastActivity = (root: Msg) =>
        (repliesByParent.get(root.id) ?? []).reduce((acc, r) => (r.createdAt > acc ? r.createdAt : acc), root.createdAt);
      roots.sort((a, b) => lastActivity(b).localeCompare(lastActivity(a)));

      if (!roots.length) {
        threadsEl.innerHTML = `<p class="muted">No threads yet. Start the conversation above.</p>`;
        return;
      }
      for (const root of roots) {
        const thread = document.createElement("div");
        thread.className = "thread card";
        thread.append(messageEl(root, true));
        const replies = (repliesByParent.get(root.id) ?? []).sort((a, b) => a.createdAt.localeCompare(b.createdAt));
        const repliesWrap = document.createElement("div");
        repliesWrap.className = "thread__replies";
        replies.forEach((rep) => repliesWrap.append(messageEl(rep, false)));
        thread.append(repliesWrap);

        const replyForm = document.createElement("form");
        replyForm.className = "chat__form chat__form--reply";
        const input = document.createElement("input");
        input.type = "text";
        input.maxLength = 280;
        input.placeholder = "Reply… (use @ to mention)";
        input.autocomplete = "off";
        const submit = document.createElement("button");
        submit.className = "btn btn--sm";
        submit.type = "submit";
        submit.textContent = "Reply";
        replyForm.append(input, submit);
        replyForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const text = input.value.trim();
          if (!text) return;
          submit.disabled = true;
          await post(text, root.id);
          input.value = "";
          submit.disabled = false;
        });
        thread.append(replyForm);
        threadsEl.append(thread);
      }
    }

    function applyData(data: { messages: Msg[]; me: string; isAdmin: boolean; allowedReactions: string[] }) {
      me = data.me;
      isAdmin = data.isAdmin;
      allowed = data.allowedReactions ?? allowed;
      render(data.messages);
    }

    async function load() {
      try {
        const r = await fetch(`/api/chat?month=${encodeURIComponent(month)}`);
        if (r.ok) applyData(await r.json());
      } catch {}
    }
    async function post(text: string, parentId: string | null, topic: string | null = null) {
      const r = await fetch("/api/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ month, text, parentId, topic }) });
      if (r.ok) { lastSig = ""; applyData(await r.json()); }
    }
    async function remove(id: string) {
      const r = await fetch(`/api/chat?month=${encodeURIComponent(month)}&id=${encodeURIComponent(id)}`, { method: "DELETE" });
      if (r.ok) { lastSig = ""; applyData(await r.json()); }
    }
    async function react(id: string, emoji: string) {
      const r = await fetch("/api/chat/react", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ month, id, emoji }) });
      if (r.ok) { lastSig = ""; applyData(await r.json()); }
    }

    const newTopicInput = document.getElementById("new-topic") as HTMLInputElement;
    newThreadForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const input = newThreadForm.querySelector("input[name='text']") as HTMLInputElement;
      const text = input.value.trim();
      if (!text) return;
      const submit = newThreadForm.querySelector("button")!;
      submit.disabled = true;
      await post(text, null, newTopicInput.value.trim() || null);
      input.value = "";
      newTopicInput.value = "";
      submit.disabled = false;
    });

    topicFilterEl.addEventListener("change", () => {
      topicFilter = topicFilterEl.value;
      lastSig = "";
      render(currentMessages);
    });

    document.addEventListener("click", (e) => {
      document.querySelectorAll(".rx-picker.is-open").forEach((p) => {
        if (!p.parentElement!.contains(e.target as Node)) p.classList.remove("is-open");
      });
    });

    // ---- @mention autocomplete ----
    const pop = document.createElement("div");
    pop.className = "mention-pop";
    pop.style.display = "none";
    document.body.append(pop);
    let activeInput: HTMLInputElement | null = null;
    let matchStart = -1;

    function hidePop() { pop.style.display = "none"; activeInput = null; }

    function showMatches(input: HTMLInputElement) {
      const caret = input.selectionStart ?? input.value.length;
      const before = input.value.slice(0, caret);
      const m = before.match(/@([a-zA-Z0-9._-]*)$/);
      if (!m) return hidePop();
      const q = m[1].toLowerCase();
      const matches = mentionables.filter((x) => x.handle.startsWith(q) || x.name.toLowerCase().includes(q)).slice(0, 6);
      if (!matches.length) return hidePop();
      activeInput = input;
      matchStart = caret - m[0].length;
      pop.innerHTML = "";
      matches.forEach((x) => {
        const b = document.createElement("button");
        b.type = "button";
        b.innerHTML = `<span>${x.name}</span><span class="handle">@${x.handle}</span>`;
        b.addEventListener("mousedown", (ev) => {
          ev.preventDefault();
          const after = input.value.slice(input.selectionStart ?? input.value.length);
          input.value = input.value.slice(0, matchStart) + "@" + x.handle + " " + after;
          const pos = matchStart + x.handle.length + 2;
          input.setSelectionRange(pos, pos);
          input.focus();
          hidePop();
        });
        pop.append(b);
      });
      const rect = input.getBoundingClientRect();
      pop.style.left = `${rect.left + window.scrollX}px`;
      pop.style.top = `${rect.bottom + window.scrollY + 4}px`;
      pop.style.width = `${Math.max(rect.width, 180)}px`;
      pop.style.display = "block";
    }

    chat.addEventListener("input", (e) => {
      const t = e.target as HTMLElement;
      if (t instanceof HTMLInputElement && t.type === "text") showMatches(t);
    });
    chat.addEventListener("keydown", (e) => {
      if (e.key === "Escape") hidePop();
    });
    document.addEventListener("click", (e) => {
      if (e.target !== activeInput && !pop.contains(e.target as Node)) hidePop();
    });

    load();
    setInterval(load, 2000);
  }

  // ---- Join + readers ----
  const joinBtn = document.getElementById("join-btn");
  const readersEl = document.getElementById("readers");
  function ini(name: string) {
    return name.split(/\s+/).filter(Boolean).slice(0, 2).map((p) => p[0]?.toUpperCase() ?? "").join("");
  }
  function renderReaders(readers: Reader[]) {
    if (!readersEl) return;
    readersEl.innerHTML = "";
    for (const r of readers) {
      const chip = document.createElement("span");
      chip.className = "reader";
      if (r.avatarUrl) {
        const img = document.createElement("img");
        img.className = "avatar avatar--sm";
        img.src = r.avatarUrl;
        chip.append(img);
      } else {
        const ph = document.createElement("span");
        ph.className = "avatar avatar--sm avatar--ph";
        ph.textContent = ini(r.displayName);
        chip.append(ph);
      }
      const name = document.createElement("span");
      name.className = "reader__name";
      name.textContent = r.displayName;
      chip.append(name);
      readersEl.append(chip);
    }
    const empty = document.getElementById("readers-empty");
    if (empty) (empty as HTMLElement).style.display = readers.length ? "none" : "";
  }
  joinBtn?.addEventListener("click", async () => {
    const month = (document.getElementById("chat") as HTMLElement)?.dataset.month;
    (joinBtn as HTMLButtonElement).disabled = true;
    try {
      const r = await fetch("/api/membership", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ month }) });
      if (r.ok) {
        const data = (await r.json()) as { readers: Reader[]; joined: boolean };
        joinBtn.textContent = data.joined ? "Leave this read" : "Join this read";
        joinBtn.dataset.joined = data.joined ? "1" : "0";
        renderReaders(data.readers);
      }
    } finally {
      (joinBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
