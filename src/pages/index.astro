---
import Layout from "@/components/Layout.astro";
import { getSession, isAdmin } from "@/lib/session";
import { listMonths, currentMonthId, userVote, tally, winnerBook, pickActive, displayLabel, scheduleText, monthName, isUpcoming } from "@/lib/months";
import { getMembers } from "@/lib/membership";
import { listProfiles, readerCards, isMember } from "@/lib/profiles";

const session = getSession(Astro.cookies);
const email = session?.email ?? null;
const admin = isAdmin(email);

// The active period is chosen by status (voting → closed → draft), not the calendar.
const allMonths = session ? await listMonths() : [];
const month = pickActive(allMonths);
const monthId = month?.id ?? currentMonthId(new Date());
const myVote = month && email ? userVote(month, email) : null;
const counts = month ? tally(month) : {};
const totalVotes = Object.values(counts).reduce((a, b) => a + b, 0);
const winner = month ? winnerBook(month) : null;
const members = month && month.phase === "closed" ? await getMembers(monthId) : [];
const readers = members.length ? await readerCards(members) : [];
const joined = email ? members.includes(email) : false;
const member = email ? await isMember(email) : false;

const today = new Date().toISOString().slice(0, 10);

// Past books of the month: anything with a chosen book that isn't the active reading.
const history = allMonths
  .filter((m) => winnerBook(m) && m.id !== monthId)
  .map((m) => ({ id: m.id, label: displayLabel(m), book: winnerBook(m)! }));

// Upcoming: future-dated periods that aren't the active one and aren't finished.
const upcoming = allMonths
  .filter((m) => m.phase !== "archived" && m.id !== monthId && isUpcoming(m, today))
  .map((m) => ({ id: m.id, label: displayLabel(m), phase: m.phase, dates: scheduleText(m) }));

// Club members for the sidebar.
const profiles = session ? await listProfiles() : [];

const monthLabel = month ? displayLabel(month) : monthName(monthId);
const monthDates = month ? scheduleText(month) : null;

function initials(name: string): string {
  return name.split(/\s+/).filter(Boolean).slice(0, 2).map((p) => p[0]?.toUpperCase() ?? "").join("");
}
---

<Layout title="TerraShelf — This month" session={session} isAdmin={admin} active="home">
  <div class="home">
    <div class="home__main">
      <p><span class="month-pill">{monthLabel}</span>{monthDates && <span class="muted" style="margin-left:0.6rem">{monthDates}</span>}</p>

      {!month || month.phase === "draft" ? (
        <div class="empty card">
          <h2>Voting hasn't opened yet</h2>
          <p>The book of the month is still being decided.{admin ? " Head to Admin to set up candidates and open voting." : " Check back soon — or drop ideas in the suggestion box."}</p>
          <p><a class="btn btn--ghost" href="/suggestions">Browse suggestions</a></p>
        </div>
      ) : month.phase === "voting" ? (
        <>
          <h1 class="page-title">Vote for {monthLabel}'s book <span class="badge badge--voting">voting open</span></h1>
          <p class="page-sub">One vote each — change it any time until voting closes.</p>
          <span id="page-month" data-month={monthId} hidden></span>
          <div class="grid grid--cards" id="candidates">
            {month.candidates.map((c) => {
              const n = counts[c.id] ?? 0;
              const pct = totalVotes ? Math.round((n / totalVotes) * 100) : 0;
              return (
                <div class={`candidate card ${myVote === c.id ? "is-mine" : ""}`} data-book-id={c.id}>
                  <div class="candidate__top">
                    {c.coverUrl ? <img class="book__cover" src={c.coverUrl} alt="" /> : <span class="book__cover">📖</span>}
                    <div>
                      <div class="book__title">{c.title}</div>
                      <div class="book__author">{c.author}</div>
                    </div>
                  </div>
                  <div class="candidate__bar"><span style={`width:${pct}%`}></span></div>
                  <div class="candidate__count">
                    <span class="js-count">{n} {n === 1 ? "vote" : "votes"}</span>
                    <button class="btn btn--sm js-vote" type="button">{myVote === c.id ? "Your vote ✓" : "Vote"}</button>
                  </div>
                </div>
              );
            })}
          </div>
        </>
      ) : (
        <>
          <h1 class="page-title">Book of the month <span class="badge badge--closed">chosen</span></h1>
          {winner && (
            <div class="hero card">
              {winner.coverUrl ? <img class="hero__cover" src={winner.coverUrl} alt="" /> : <div class="hero__cover"></div>}
              <div class="hero__body">
                <div class="hero__kicker">{monthLabel}</div>
                <h2 class="hero__title">{winner.title}</h2>
                <div class="hero__author">{winner.author}</div>
                <div class="hero__actions">
                  {member ? (
                    <button class="btn js-join" id="join-btn" data-joined={joined ? "1" : "0"}>
                      {joined ? "Leave this read" : "Join this read"}
                    </button>
                  ) : (
                    <a class="btn btn--ghost" href="/profile">Set up your profile to join →</a>
                  )}
                  <a class="btn btn--muted" href={`/month/${monthId}`}>Open the discussion →</a>
                </div>
                <div class="readers" id="readers" style="margin-top:0.9rem">
                  {readers.map((r) => (
                    <span class="reader">
                      {r.avatarUrl ? <img class="avatar avatar--sm" src={r.avatarUrl} alt="" /> : <span class="avatar avatar--sm avatar--ph">{initials(r.displayName)}</span>}
                      <span class="reader__name">{r.displayName}</span>
                    </span>
                  ))}
                </div>
                <p class="muted" id="readers-empty" style={readers.length ? "display:none" : ""}>No readers yet — be the first to join.</p>
              </div>
            </div>
          )}
          <span id="page-month" data-month={monthId} hidden></span>
        </>
      )}

      {upcoming.length > 0 && (
        <section>
          <h2 class="page-title" style="font-size:1.4rem;margin-top:2rem">Upcoming <span class="badge badge--upcoming">soon</span></h2>
          <div class="stack">
            {upcoming.map((u) => (
              <div class="card book history__item">
                <span class="book__cover">🗓️</span>
                <div style="flex:1">
                  <div class="book__title">{u.label}</div>
                  <div class="book__author">{u.phase === "voting" ? "Voting soon" : "Being prepared"}{u.dates ? ` · ${u.dates}` : ""}</div>
                </div>
                <span class="badge badge--upcoming">upcoming</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="history-section">
        <h2 class="page-title" style="font-size:1.4rem;margin-top:2rem">Past books of the month</h2>
        {history.length === 0 ? (
          <p class="muted">No past books yet — the shelf starts filling up once a month closes.</p>
        ) : (
          <div class="stack">
            {history.map((h) => (
              <a class="card book history__item" href={`/month/${h.id}`}>
                {h.book.coverUrl ? <img class="book__cover" src={h.book.coverUrl} alt="" /> : <span class="book__cover">📖</span>}
                <div style="flex:1">
                  <div class="hero__kicker">{h.label}</div>
                  <div class="book__title">{h.book.title}</div>
                  <div class="book__author">{h.book.author}</div>
                </div>
                <span class="muted">Discussion →</span>
              </a>
            ))}
          </div>
        )}
      </section>
    </div>

    <aside class="home__aside">
      <div class="card members-widget">
        <div class="members-widget__count">{profiles.length}</div>
        <p class="members-widget__label">{profiles.length === 1 ? "member so far" : "members so far"}</p>
        <div class="member-thumbs">
          {profiles.map((p) => (
            <a href="/members" title={p.displayName}>
              {p.avatarUrl ? <img class="avatar avatar--sm" src={p.avatarUrl} alt={p.displayName} /> : <span class="avatar avatar--sm avatar--ph">{initials(p.displayName)}</span>}
            </a>
          ))}
        </div>
        <a class="btn btn--ghost btn--sm" href="/members" style="margin-top:0.5rem">See all members</a>
      </div>
    </aside>
  </div>
</Layout>

<script>
  // ---- Voting ----
  const candidates = document.getElementById("candidates");
  if (candidates) {
    candidates.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".js-vote");
      if (!btn) return;
      const cardEl = btn.closest<HTMLElement>(".candidate");
      const bookId = cardEl?.dataset.bookId;
      if (!bookId) return;
      btn.disabled = true;
      const month = (document.getElementById("page-month") as HTMLElement)?.dataset.month;
      try {
        const r = await fetch("/api/vote", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ month, bookId }),
        });
        if (r.ok) {
          const data = (await r.json()) as { tally: Record<string, number>; myVote: string };
          updateTally(data.tally, data.myVote);
        }
      } finally {
        btn.disabled = false;
      }
    });
  }

  function updateTally(tally: Record<string, number>, myVote: string) {
    const total = Object.values(tally).reduce((a, b) => a + b, 0);
    document.querySelectorAll<HTMLElement>(".candidate").forEach((card) => {
      const id = card.dataset.bookId!;
      const n = tally[id] ?? 0;
      const pct = total ? Math.round((n / total) * 100) : 0;
      card.querySelector<HTMLElement>(".candidate__bar > span")!.style.width = pct + "%";
      card.querySelector(".js-count")!.textContent = `${n} ${n === 1 ? "vote" : "votes"}`;
      const mine = id === myVote;
      card.classList.toggle("is-mine", mine);
      card.querySelector(".js-vote")!.textContent = mine ? "Your vote ✓" : "Vote";
    });
  }

  // ---- Join + readers ----
  type Reader = { email: string; displayName: string; avatarUrl: string };
  const joinBtn = document.getElementById("join-btn");
  const readersEl = document.getElementById("readers");

  function ini(name: string) {
    return name.split(/\s+/).filter(Boolean).slice(0, 2).map((p) => p[0]?.toUpperCase() ?? "").join("");
  }

  function renderReaders(readers: Reader[]) {
    if (!readersEl) return;
    readersEl.innerHTML = "";
    for (const r of readers) {
      const chip = document.createElement("span");
      chip.className = "reader";
      if (r.avatarUrl) {
        const img = document.createElement("img");
        img.className = "avatar avatar--sm";
        img.src = r.avatarUrl;
        chip.append(img);
      } else {
        const ph = document.createElement("span");
        ph.className = "avatar avatar--sm avatar--ph";
        ph.textContent = ini(r.displayName);
        chip.append(ph);
      }
      const name = document.createElement("span");
      name.className = "reader__name";
      name.textContent = r.displayName;
      chip.append(name);
      readersEl.append(chip);
    }
    const empty = document.getElementById("readers-empty");
    if (empty) (empty as HTMLElement).style.display = readers.length ? "none" : "";
  }

  joinBtn?.addEventListener("click", async () => {
    const month = (document.getElementById("page-month") as HTMLElement)?.dataset.month;
    (joinBtn as HTMLButtonElement).disabled = true;
    try {
      const r = await fetch("/api/membership", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ month }),
      });
      if (r.ok) {
        const data = (await r.json()) as { readers: Reader[]; joined: boolean };
        joinBtn.textContent = data.joined ? "Leave this read" : "Join this read";
        joinBtn.dataset.joined = data.joined ? "1" : "0";
        renderReaders(data.readers);
      }
    } finally {
      (joinBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
