---
import Layout from "@/components/Layout.astro";
import { getSession, isAdmin } from "@/lib/session";
import { listProfiles } from "@/lib/profiles";

const session = getSession(Astro.cookies);
const admin = isAdmin(session?.email);
const profiles = session ? await listProfiles() : [];
---

<Layout title="TerraShelf — Members" session={session} isAdmin={admin} active="members">
  <h1 class="page-title">Members</h1>
  <p class="page-sub">Who's in the club, their Goodreads, and their all-time top 3.</p>

  {profiles.length === 0 ? (
    <div class="empty card">
      <h2>No profiles yet</h2>
      <p>Be the first — set up <a href="/profile">your profile</a>.</p>
    </div>
  ) : (
    <div class="grid grid--cards">
      {profiles.map((p) => (
        <div class="card member">
          <div class="member__name">{p.displayName}</div>
          <div class="member__email">{p.email}</div>
          {p.bio && <p class="muted" style="margin:0">{p.bio}</p>}
          {p.goodreadsUrl && (
            <a class="goodreads" href={p.goodreadsUrl} target="_blank" rel="noopener noreferrer">Goodreads ↗</a>
          )}
          {p.topBooks.length > 0 && (
            <>
              <div class="section-label">Top {p.topBooks.length}</div>
              <div class="member__top">
                {p.topBooks.map((b) =>
                  b.coverUrl ? <img src={b.coverUrl} alt={b.title} title={`${b.title} — ${b.author}`} /> : <span class="result__ph" title={b.title}></span>
                )}
              </div>
            </>
          )}
        </div>
      ))}
    </div>
  )}
</Layout>
