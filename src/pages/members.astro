---
import Layout from "@/components/Layout.astro";
import { getSession, isAdmin, adminRole } from "@/lib/session";
import { listProfiles, accentForEmail } from "@/lib/profiles";

const session = getSession(Astro.cookies);
const admin = isAdmin(session?.email);
const allProfiles = session ? await listProfiles() : [];
// Admins first (primary, then co-admins), then everyone else alphabetically.
const rank = (email: string) => (adminRole(email) === "admin" ? 0 : adminRole(email) === "co-admin" ? 1 : 2);
const profiles = [...allProfiles].sort((a, b) => rank(a.email) - rank(b.email) || a.displayName.localeCompare(b.displayName));

function initials(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((p) => p[0]?.toUpperCase() ?? "")
    .join("");
}
---

<Layout title="TerraShelf — Members" session={session} isAdmin={admin} active="members">
  <h1 class="page-title">Members</h1>
  <p class="page-sub">Who's in the club, their Goodreads, and their all-time top 3.</p>

  {profiles.length === 0 ? (
    <div class="empty card">
      <h2>No profiles yet</h2>
      <p>Be the first — set up <a href="/profile">your profile</a>.</p>
    </div>
  ) : (
    <div class="grid grid--members">
      {profiles.map((p) => {
        const role = adminRole(p.email);
        const accent = role ? "var(--pink)" : accentForEmail(p.email);
        return (
          <div class="card member" style={`border-top-color:${accent}`}>
            <div class="member__head">
              {p.avatarUrl ? (
                <img class="avatar" src={p.avatarUrl} alt={p.displayName} />
              ) : (
                <span class="avatar avatar--ph" style={`background:${accent}`}>{initials(p.displayName)}</span>
              )}
              <div>
                <div class="member__name">
                  {p.displayName}
                  {role && <span class="badge badge--admin">{role === "admin" ? "Admin" : "Co-admin"}</span>}
                </div>
                <div class="member__email">{p.email}</div>
              </div>
            </div>
            {p.bio && <p class="member__bio">{p.bio}</p>}
            {p.goodreadsUrl && (
              <a class="goodreads" href={p.goodreadsUrl} target="_blank" rel="noopener noreferrer" style={`color:${accent}`}>Goodreads ↗</a>
            )}
            {p.topBooks.length > 0 && (
              <>
                <div class="section-label">Top {p.topBooks.length}</div>
                <div class="member__top">
                  {p.topBooks.map((b) => (
                    <div class="member__book">
                      {b.coverUrl ? <img src={b.coverUrl} alt={b.title} /> : <span class="result__ph"></span>}
                      <span class="member__book-title" title={`${b.title}${b.author ? " — " + b.author : ""}`}>{b.title}</span>
                    </div>
                  ))}
                </div>
              </>
            )}
          </div>
        );
      })}
    </div>
  )}
</Layout>
